# ── Database ──────────────────────────────────────────────────────────────────
# Option A: Local PostgreSQL
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/studysync

# Option B: Free cloud DB (Neon, Supabase, Railway)
# DATABASE_URL=postgresql://user:pass@host/dbname

# ── Session Secret ────────────────────────────────────────────────────────────
# Any long random string — change this before deploying!
SESSION_SECRET=studysync-super-secret-change-me-in-production-2024

# ── Server ────────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development
